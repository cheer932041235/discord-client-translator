{
  "server": {
    "host": "127.0.0.1",
    "port": 3789
  },
  "deepseek": {
    "baseUrl": "https://api.deepseek.com",
    "chatPath": "/v1/chat/completions",
    "apiKeyEnv": "DEEPSEEK_API_KEY",
    "model": "deepseek-v4-flash",
    "timeoutMs": 20000,
    "temperature": 0.2,
